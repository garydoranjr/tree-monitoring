%% Canopy Observability Pipeline — data flow between scripts
%%
%% Conventions:
%%   [Script]           = Python / notebook step
%%   ([artifact])       = data file (input or output)
%%   "? foo"            = artifact whose upstream producer is not documented
%%                        in docs/observability_methodology.md (matches a
%%                        "Reproduce: TODO" placeholder there).
%%
%% Subgraphs mirror the seven steps in docs/observability_methodology.md.
%% The earlier UDM2 scene-level cloud screening analysis and its scripts
%% have been retired; see docs/history.md.
%%
%% Cross-cutting note: scripts/windowed_obs_counts.py is drawn inside Step 6
%% because its primary consumer (scripts/illumination.py) lives there, but
%% it also operates on the Step 4 assessment.npz that feeds Step 7.

flowchart TD

  subgraph S123["Steps 1-3: Labels, Embeddings, Classifier"]
    s2_labels(["luis/20240723b_individual.csv"])
    s3_chips[("? crown_chip_dir")] --> s3_ie["scripts/image_embedding.py"]
    s3_ie --> s3_emb[("? embeddings_dir/*.json")]
    s2_labels --> s4_rf["luis/RandomForest_train.py"]
    s3_emb --> s4_rf
    s4_rf --> s4_model(["model.skops"])
  end

  subgraph S4["Step 4: Visibility Assessment"]
    s4_model --> s5_va["scripts/visibility_assessment.py"]
    s3_emb --> s5_va
    s5_va --> s5_ass(["results/assessment.npz"])
  end

  subgraph S5["Step 5: Cadence"]
    s5_ass --> s6_pac["scripts/plot_assessed_cadence.py"]
    s5_ass --> s6_pavc["scripts/plot_avg_assessed_cadence.py"]
    s6_pavc --> s6_avg(["results/avg_assessed_cadence.npz"])
    s6_frac[("? monthly_fraction_csv")] --> s6_pfm["scripts/plot_planet_image_fraction_monthly.py"]
  end

  subgraph S6["Step 6: Solar Radiation Validation"]
    s5_ass --> s7_woc["scripts/windowed_obs_counts.py"]
    s7_woc --> s7_w05(["results/windowed_obs_counts_05d.npz"])
    s7_w05 --> s7_ill["scripts/illumination.py"]
    s7_rade(["data/radiation/bci_lutz48m_sre_elect.csv"]) --> s7_ill
    s7_radw(["data/radiation/bci_lutz48m_srw_elect.csv"]) --> s7_ill
  end

  subgraph S7["Step 7: Phenological Event Observability"]
    s5_ass --> s8_fecm["scripts/fit_empirical_count_models.py"]
    s8_fecm --> s8_emp(["results/empirical_model.npz"])

    s8_raw(["data/BCI_TRAP200_20241002_spcorrected.txt"]) --> s8_gatd["scripts/get_annual_trap_data.py"]
    s8_gatd --> s8_flow(["results/sp_flower_counts_annual.npz"])
    s8_gatd --> s8_frui(["results/sp_fruit_counts_annual.npz"])

    s8_flow --> s8_ita["scripts/individual_trap_analysis.py"]
    s8_frui --> s8_ita
    s8_ita --> s8_fev(["results/sp_flower_counts_annual_stats.csv"])
    s8_ita --> s8_frev(["results/sp_fruit_counts_annual_stats.csv"])

    s8_leaf(["data/df_LeafCoverTimeSeries_byTags_all_2024.csv"]) --> s8_ida["scripts/individual_decid_analysis.py"]
    s8_ida --> s8_dec(["results/decid_summary.csv"])

    s8_emp --> s8_ess["scripts/event_summary_stats.py"]
    s8_fev --> s8_ess
    s8_frev --> s8_ess
    s8_dec --> s8_ess
    s8_ess --> s8_fstats(["results/flower_summary_stats.csv"])
    s8_ess --> s8_frstats(["results/fruit_summary_stats.csv"])
    s8_ess --> s8_dstats(["results/decid_summary_stats.csv"])

    s8_emp --> s8_pts["scripts/plot_trap_summary.py"]
    s8_fev --> s8_pts
    s8_frev --> s8_pts
    s8_dec --> s8_pts
    s8_pts --> s8_fpdf(["figs/sp_flower_counts_annual_stats.pdf"])
    s8_pts --> s8_frpdf(["figs/sp_fruit_counts_annual_stats.pdf"])
    s8_pts --> s8_dpdf(["figs/decid_summary.pdf"])
  end
